        <mxCell id="title" value="Self-Healing EC2 Fleet — Enterprise AWS Architecture" style="text;html=1;align=center;fontSize=27;fontStyle=1;fontColor=#172B4D;" vertex="1" parent="1"><mxGeometry x="220" y="18" width="1160" height="40" as="geometry"/></mxCell>

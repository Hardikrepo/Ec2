        <mxCell id="albsg" value="ALB Security Group&#xa;Inbound TCP/80 · 0.0.0.0/0" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.security_group;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=9;" vertex="1" parent="1"><mxGeometry x="305" y="310" width="58" height="58" as="geometry"/></mxCell>
